{
  "name": "@20minutes/eslint-config",
  "version": "3.0.3",
  "description": "Shared Biome linting/formatting config for 20 Minutes",
  "author": "20 Minutes",
  "license": "MIT",
  "type": "module",
  "main": "biome.jsonc",
  "exports": {
    "./biome": "./biome.jsonc"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.12"
  },
  "repository": "20minutes/eslint-config",
  "engines": {
    "node": ">= 22.21.1"
  },
  "scripts": {
    "lint": "biome check",
    "lint:fix": "biome check --write --unsafe"
  },
  "keywords": [
    "20minutes",
    "code",
    "quality",
    "style",
    "lint",
    "linter",
    "validate",
    "code style",
    "strict",
    "check",
    "checker",
    "verify",
    "enforce",
    "hint",
    "biome"
  ]
}
